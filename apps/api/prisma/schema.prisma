generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE STRUCTURE ───────────────────────────────────────

model Project {
  id        String      @id @default(uuid())
  name      String
  type      ProjectType
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  branches           Branch[]
  projectDepartments ProjectDepartment[]
  managerScopes      UserManagerScope[]
}

enum ProjectType {
  HOSPITAL
  VTI
  KITCHEN
  SOFTWARE_HOUSE
}

model Branch {
  id           String   @id @default(uuid())
  name         String
  abbreviation String?
  address      String?
  phone     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(999)
  createdAt DateTime @default(now())
  projectId String?

  project           Project?            @relation(fields: [projectId], references: [id])
  departments       Department[]
  employees         Employee[]
  employmentHistory EmploymentHistory[]
  attendanceLogs    AttendanceLog[]
  shifts            Shift[]
  relieverSessions  RelieverSession[]
  location          BranchLocation?
  biometricDevices  BiometricDevice[]
  adminUsers        User[]
  faceSyncResults   FaceSyncResult[]
  mutualSwaps       MutualSwap[]
}

model BiometricDevice {
  id        String   @id @default(uuid())
  deviceId  String   @unique
  branchId  String
  label     String?
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
}

model FaceSyncJob {
  id         String   @id @default(uuid())
  employeeId String
  photoUrl   String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee         @relation(fields: [employeeId], references: [id])
  results  FaceSyncResult[]
}

model FaceSyncResult {
  id       String   @id @default(uuid())
  jobId    String
  deviceId String
  branchId String
  status   String
  error    String?
  syncedAt DateTime @default(now())

  job    FaceSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  branch Branch      @relation(fields: [branchId], references: [id])

  @@unique([jobId, deviceId])
}

model Shift {
  id        String   @id @default(uuid())
  branchId  String?
  name      String
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  branch      Branch?      @relation(fields: [branchId], references: [id])
  employees   Employee[]
  mutualSwaps MutualSwap[]

  @@unique([name, startTime, endTime])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  sortOrder Int      @default(999)
  createdAt DateTime @default(now())

  employees          Employee[]
  employmentHistory  EmploymentHistory[]
  projectDepartments ProjectDepartment[]
  managerScopes      UserManagerScope[]
}

/// Links a HOSPITAL project to departments that may be assigned as manager scopes.
model ProjectDepartment {
  id           String   @id @default(uuid())
  projectId    String
  departmentId String
  createdAt    DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([projectId, departmentId])
  @@index([projectId])
  @@index([departmentId])
}

// ─── EMPLOYEE ─────────────────────────────────────────────

model Employee {
  id                  String         @id @default(uuid())
  employeeCode        String         @unique
  fullName            String
  fatherName          String?
  cnic                String?        @unique
  phone               String?
  email               String?        @unique
  dateOfBirth         DateTime?
  gender              Gender
  address             String?
  joiningDate         DateTime
  status              EmployeeStatus @default(ACTIVE)
  currentBranchId     String
  currentDepartmentId String?
  currentDesignation  String?
  biometricId         String?        @unique
  shiftId             String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  currentBranch     Branch     @relation(fields: [currentBranchId], references: [id])
  currentDepartment Department? @relation(fields: [currentDepartmentId], references: [id])
  shift             Shift?     @relation(fields: [shiftId], references: [id])

  employmentHistory   EmploymentHistory[]
  documents           EmployeeDocument[]
  stipendRecords      StipendRecord[]
  attendanceLogs      AttendanceLog[]
  disciplinaryActions DisciplinaryAction[]
  letters             Letter[]
  leaveRecords        LeaveRecord[]
  notifications       Notification[]
  relieverSessions    RelieverSession[]
  letterReplies              LetterReply[]
  user                       User?
  academicQualifications     AcademicQualification[]
  previousEmployments        PreviousEmployment[]
  branchChangeRequests       BranchChangeRequest[]
  allegationAcknowledgements AllegationAcknowledgement[]
  relieverRequestsMade       RelieverRequest[] @relation("RelieverRequester")
  relieverRequestsReceived   RelieverRequest[] @relation("RelieverEmployee")
  stipendReceipts            StipendReceipt[]
  incentives                 Incentive[]
  portalAttendances          PortalAttendance[]
  advanceLoanRequests        AdvanceLoanRequest[]
  faceSyncJobs               FaceSyncJob[]
  onboardingApproval       EmployeeOnboardingApproval?
  coveringSwaps              MutualSwap[] @relation("CoveringSwaps")
  coveredSwaps               MutualSwap[] @relation("CoveredSwaps")

  // Additional personal info
  fatherStatus           String?
  guardianContact        String?
  fatherContactNumber    String?
  emergencyContactName   String?
  emergencyContactNumber String?
  emergencyRelation      String?
  spouseName             String?
  spouseContactNumber    String?
  photoUrl               String?
  privatePhotoUrl        String?
  hideProfilePhoto       Boolean        @default(false)
  caste                  String?
  domicile               String?
  currentAddress         String?
  permanentAddress       String?
  district               String?
  tehsil                 String?
  policeStation          String?
  bloodGroup             String?
  staffType              StaffType      @default(NEW)
  dutyStartTime          String?
  dutyEndTime            String?
  dutyTotalHours         Int?
  province               String?
  city                   String?
  permanentProvince      String?
  permanentCity          String?
  maritalStatus          MaritalStatus?
}

enum MaritalStatus {
  MARRIED
  UNMARRIED
  DIVORCED
  WIDOW
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StaffType {
  NEW
  EXISTING
  INTERNEE
}

enum EmployeeStatus {
  TRAINEE
  ACTIVE
  APPOINTED
  SUSPENDED
  TERMINATED
  RESIGNED
  DISMISSED
  ON_LEAVE
  ON_REST
  PENDING_APPROVAL
}

enum EmployeeApproverTarget {
  PRESIDENT
  FOUNDER
  CHAIRMAN_ADMIN
}

enum EmployeeOnboardingStatus {
  PENDING
  APPROVED
  REJECTED
}

model EmployeeOnboardingApproval {
  id                     String                   @id @default(uuid())
  employeeId             String                   @unique
  submittedById          String
  approverTarget         EmployeeApproverTarget
  status                 EmployeeOnboardingStatus @default(PENDING)
  formSnapshot           Json
  physicalFormUrl        String?
  physicalFormMimeType   String?
  physicalFormFileName   String?
  reviewNote             String?
  reviewedById           String?
  reviewedAt             DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  submittedBy User     @relation("SubmittedOnboardingApprovals", fields: [submittedById], references: [id])
  reviewedBy  User?    @relation("ReviewedOnboardingApprovals", fields: [reviewedById], references: [id])
}

model RelieverSession {
  id           String    @id @default(uuid())
  employeeId   String
  branchId     String
  date         DateTime  @db.Date
  checkIn      DateTime
  checkOut     DateTime?
  totalMinutes Int       @default(0)
  createdAt    DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
}

// ─── DESIGNATIONS ───────────────────────────────────────────

model Designation {
  id        String   @id @default(uuid())
  title     String   @unique
  category  String
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  sortOrder Int      @default(999)
  createdAt DateTime @default(now())

  managerScopes UserManagerScope[]
}

// ─── EMPLOYMENT HISTORY ───────────────────────────────────

model EmploymentHistory {
  id            String     @id @default(uuid())
  employeeId    String
  branchId      String
  departmentId  String
  designation   String
  changeType    ChangeType
  changeReason  String?
  effectiveDate DateTime
  endDate       DateTime?
  createdAt     DateTime   @default(now())

  employee   Employee   @relation(fields: [employeeId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
}

enum ChangeType {
  JOINED
  TRANSFERRED
  PROMOTED
  DEMOTED
  REINSTATED
  REJOINED
}

// ─── DOCUMENTS ────────────────────────────────────────────

model EmployeeDocument {
  id           String       @id @default(uuid())
  employeeId   String
  documentType DocumentType
  fileName     String
  fileUrl      String
  uploadedAt   DateTime     @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum DocumentType {
  CNIC
  EDUCATIONAL_CERTIFICATE
  EXPERIENCE_LETTER
  MEDICAL_CERTIFICATE
  OTHER
}

// ─── ATTENDANCE ───────────────────────────────────────────

model AttendanceLog {
  id              String           @id @default(uuid())
  employeeId      String
  branchId        String
  date            DateTime         @db.Date
  type            AttendanceLogType  @default(REGULAR)
  checkIn         DateTime?
  checkOut        DateTime?
  status          AttendanceStatus
  lateMinutes     Int              @default(0)
  overtimeMinutes Int              @default(0)
  overtimePending Boolean          @default(false)
  overtimeApprovedBy String?
  overtimeApprovedAt DateTime?
  source          AttendanceSource @default(BIOMETRIC)
  note            String?
  createdAt       DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@unique([employeeId, date, type])
}

enum AttendanceLogType {
  REGULAR
  OVERTIME
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  UNMARKED
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
  UNINFORMED_ABSENT
  SWAP_COVERED
}

enum AttendanceSource {
  BIOMETRIC
  MANUAL
}

// ─── STIPEND ──────────────────────────────────────────────

model StipendRecord {
  id               String    @id @default(uuid())
  employeeId       String
  basicStipend     Decimal   @db.Decimal(10, 2)
  allowances       Decimal?  @db.Decimal(10, 2)
  reward           Decimal?  @db.Decimal(10, 2)
  progressReward  Decimal?  @db.Decimal(10, 2)
  fuelAllowance    Decimal?  @db.Decimal(10, 2)
  loanDeduction    Decimal?  @db.Decimal(10, 2)
  advanceDeduction Decimal?  @db.Decimal(10, 2)
  fineDeduction    Decimal?  @db.Decimal(10, 2)
  healthDeduction  Decimal?  @db.Decimal(10, 2)
  lumpsumTotal     Decimal?  @db.Decimal(10, 2)
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  createdAt        DateTime  @default(now())

  employee       Employee       @relation(fields: [employeeId], references: [id])
  payrollEntries PayrollEntry[]
}

model PayrollEntry {
  id              String        @id @default(uuid())
  stipendRecordId String
  month           Int
  year            Int
  basicStipend    Decimal       @db.Decimal(10, 2)
  totalDeductions Decimal       @db.Decimal(10, 2) @default(0)
  totalAllowances Decimal       @db.Decimal(10, 2) @default(0)
  netStipend      Decimal       @db.Decimal(10, 2)
  status          PayrollStatus @default(PENDING)
  processedAt     DateTime?
  createdAt       DateTime      @default(now())

  stipendRecord  StipendRecord      @relation(fields: [stipendRecordId], references: [id])
  deductions     PayrollDeduction[]
  allowances     Allowance[]
  stipendReceipt StipendReceipt?

  @@unique([stipendRecordId, month, year])
}

model Allowance {
  id             String        @id @default(uuid())
  payrollEntryId String
  type           AllowanceType
  description    String?
  amount         Decimal       @db.Decimal(10, 2)
  hours          Decimal?      @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())

  payrollEntry PayrollEntry @relation(fields: [payrollEntryId], references: [id])
}

enum AllowanceType {
  OVERTIME
  RELIEVER
  CUSTOM
}

model PayrollDeduction {
  id             String        @id @default(uuid())
  payrollEntryId String
  reason         DeductionType
  amount         Decimal       @db.Decimal(10, 2)
  description    String?

  payrollEntry PayrollEntry @relation(fields: [payrollEntryId], references: [id])
}

enum DeductionType {
  LATE_ARRIVAL
  UNINFORMED_ABSENCE
  DISCIPLINARY_FINE
  OTHER
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

// ─── DISCIPLINARY ─────────────────────────────────────────

model DisciplinaryAction {
  id         String             @id @default(uuid())
  employeeId String
  type       DisciplinaryType
  reason     String
  status     DisciplinaryStatus @default(OPEN)
  issuedAt   DateTime           @default(now())
  resolvedAt DateTime?
  resolution String?
  createdAt  DateTime           @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  inquiry  Inquiry?
}

enum DisciplinaryType {
  WARNING
  SHOW_CAUSE
  FINE
  SUSPENSION
  TERMINATION
}

enum DisciplinaryStatus {
  OPEN
  UNDER_INQUIRY
  RESOLVED
  DISMISSED
}

model Inquiry {
  id                   String         @id @default(uuid())
  disciplinaryActionId String         @unique
  startedAt            DateTime       @default(now())
  deadlineAt           DateTime
  outcome              InquiryOutcome?
  notes                String?
  closedAt             DateTime?

  disciplinaryAction DisciplinaryAction @relation(fields: [disciplinaryActionId], references: [id])
}

enum InquiryOutcome {
  REINSTATED
  TERMINATED
  REJOINED
  DISMISSED
}

// ─── LETTERS ──────────────────────────────────────────────

model Letter {
  id            String     @id @default(uuid())
  employeeId    String
  letterType    LetterType
  content       Json
  generatedAt   DateTime   @default(now())
  printedAt     DateTime?
  fileUrl       String?
  replyDeadline DateTime?
  isReplied     Boolean    @default(false)
  autoEscalated           Boolean @default(false)
  requiresAcknowledgement Boolean @default(false)

  employee        Employee                   @relation(fields: [employeeId], references: [id])
  replies         LetterReply[]
  acknowledgement AllegationAcknowledgement?
}

model LetterReply {
  id         String   @id @default(uuid())
  letterId   String
  employeeId String
  replyText  String   @db.Text
  repliedAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  letter   Letter   @relation(fields: [letterId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

enum LetterType {
  APPOINTMENT
  WARNING
  ADVICE
  DISCIPLINARY
  EXPLANATION
  SHOW_CAUSE
  FINE
  INQUIRY
  APPRECIATION
  TRANSFER
  SUSPENSION
  TERMINATION
  REINSTATEMENT
  REJOINING
  SALARY_INCREMENT
  EXPERIENCE
}

// ─── LEAVE ────────────────────────────────────────────────

model LeaveRecord {
  id               String               @id @default(uuid())
  employeeId       String
  leaveType        LeaveType            @default(REGULAR)
  startDate        DateTime
  endDate          DateTime
  totalDays        Int
  status           LeaveStatus          @default(PENDING)
  reason           String?
  approvedBy       String?
  currentStage     LeaveApprovalStage?  @default(BRANCH_MANAGER)
  branchManagerId  String?
  deptInchargeId   String?
  createdAt        DateTime             @default(now())

  employee        Employee        @relation(fields: [employeeId], references: [id])
  relieverRequest RelieverRequest?
  approvals       LeaveApproval[]
}

model LeaveApproval {
  id       String              @id @default(uuid())
  leaveId  String
  stage    LeaveApprovalStage
  action   LeaveApprovalAction
  actionBy String
  actionAt DateTime            @default(now())
  notes    String?
  createdAt DateTime           @default(now())

  leave        LeaveRecord @relation(fields: [leaveId], references: [id])
  actionByUser User        @relation("LeaveApprovals", fields: [actionBy], references: [id])
}

enum LeaveApprovalStage {
  BRANCH_MANAGER
  DEPARTMENT_INCHARGE
  HR_OPERATIONS
}

enum LeaveApprovalAction {
  APPROVED
  REJECTED
}

enum LeaveType {
  REGULAR
  SHORT_LEAVE
  EMERGENCY
}

enum LeaveStatus {
  PENDING
  BRANCH_APPROVED
  DEPT_APPROVED
  RELIEVER_PENDING
  RELIEVER_CONFIRMED
  RELIEVER_REJECTED
  HR_PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StipendStatus {
  PENDING
  ACCEPTED
  REJECTED
  AUTO_ACCEPTED
}

enum RelieverRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  AUTO_REJECTED
  HR_ASSIGNED
}

model RelieverRequest {
  id             String                @id @default(uuid())
  leaveRecordId  String                @unique
  requestedById  String
  relieverId     String
  status         RelieverRequestStatus @default(PENDING)
  requestedAt    DateTime              @default(now())
  respondedAt    DateTime?
  autoRejectedAt DateTime?
  hrAssigned     Boolean               @default(false)
  hrAssignedBy   String?
  hrAssignedAt   DateTime?
  notes          String?
  createdAt      DateTime              @default(now())

  leaveRecord LeaveRecord @relation(fields: [leaveRecordId], references: [id])
  requestedBy Employee    @relation("RelieverRequester", fields: [requestedById], references: [id])
  reliever    Employee    @relation("RelieverEmployee", fields: [relieverId], references: [id])
}

model StipendReceipt {
  id              String        @id @default(uuid())
  employeeId      String
  payrollEntryId  String        @unique
  month           Int
  year            Int
  amount          Decimal       @db.Decimal(10, 2)
  status          StipendStatus @default(PENDING)
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  autoAcceptedAt  DateTime?
  generatedAt     DateTime      @default(now())
  deadlineAt      DateTime

  employee     Employee     @relation(fields: [employeeId], references: [id])
  payrollEntry PayrollEntry @relation(fields: [payrollEntryId], references: [id])
}

model Incentive {
  id         String   @id @default(uuid())
  employeeId String
  amount     Decimal  @db.Decimal(10, 2)
  reason     String   @db.Text
  addedBy    String
  month      Int
  year       Int
  createdAt  DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id])
  addedByUser User     @relation(fields: [addedBy], references: [id])
}

// ─── AUTH & USERS ─────────────────────────────────────────

model User {
  id         String    @id @default(uuid())
  employeeId String?   @unique
  email      String    @unique
  password   String
  role       UserRole
  branchId   String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastLogin  DateTime?

  employee   Employee?               @relation(fields: [employeeId], references: [id])
  branch     Branch?                 @relation(fields: [branchId], references: [id])
  auditLogs  AuditLog[]
  broadcasts NotificationBroadcast[]
  incentivesAdded Incentive[]
  leaveApprovals LeaveApproval[] @relation("LeaveApprovals")
  passwordRecord UserPassword?
  permissions    UserPermission[]
  additionalRoles UserAdditionalRole[]
  managerScopes   UserManagerScope[]
  submittedOnboardingApprovals EmployeeOnboardingApproval[] @relation("SubmittedOnboardingApprovals")
  reviewedOnboardingApprovals  EmployeeOnboardingApproval[] @relation("ReviewedOnboardingApprovals")
  mutualSwapsCreated           MutualSwap[]
}

model UserAdditionalRole {
  id        String   @id @default(uuid())
  userId    String
  role      UserRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

/// Hospital department/designation manager scopes (Admin Officer–equivalent within match).
model UserManagerScope {
  id            String   @id @default(uuid())
  userId        String
  projectId     String
  departmentId  String
  designationId String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  designation Designation? @relation(fields: [designationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([departmentId])
  @@index([userId, projectId, departmentId, designationId])
}

model MutualSwap {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date

  coveringEmployeeId String
  coveringEmployee   Employee @relation("CoveringSwaps", fields: [coveringEmployeeId], references: [id])

  coveredEmployeeId  String
  coveredEmployee    Employee @relation("CoveredSwaps", fields: [coveredEmployeeId], references: [id])

  coveredShiftId     String
  coveredShift       Shift    @relation(fields: [coveredShiftId], references: [id])

  branchId           String
  branch             Branch   @relation(fields: [branchId], references: [id])

  status             String   @default("ACTIVE")
  note               String?
  createdById        String
  createdBy          User     @relation(fields: [createdById], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserPermission {
  id         String     @id @default(uuid())
  userId     String
  permission Permission
  granted    Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

model UserPassword {
  id        String   @id @default(uuid())
  userId    String   @unique
  plainText String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BranchLocation {
  id        String   @id @default(uuid())
  branchId  String   @unique
  latitude  Float
  longitude Float
  radius    Int      @default(200)
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model PortalAttendance {
  id         String   @id @default(uuid())
  employeeId String
  type       String
  latitude   Float
  longitude  Float
  timestamp  DateTime @default(now())
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum Permission {
  ATTENDANCE_MARK
  ATTENDANCE_EDIT
  LEAVE_APPROVE
  LEAVE_APPLY_OTHERS
  PAYROLL_MANAGE
  EMPLOYEES_CREATE
  EMPLOYEES_EDIT
  DISCIPLINARY_MANAGE
  LETTERS_GENERATE
  INCENTIVES_MANAGE
  RECRUITMENT_MANAGE
  REPORTS_VIEW
  BROADCASTS_SEND
  ORG_SETUP
}

enum UserRole {
  SUPER_ADMIN
  IT_ADMIN
  PRESIDENT
  FOUNDER
  CHAIRMAN
  HR_OPERATIONS_MANAGER
  HR_ADMIN_MANAGER
  HR_EXECUTIVE
  ADMIN_OFFICER
  HR_MANAGER
  ADMIN_MANAGER
  MEDICINE_MANAGER
  DEPARTMENT_HEAD
  PAYROLL_OFFICER
  EMPLOYEE
}

// ─── NOTIFICATIONS ────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  employeeId String
  message    String
  type       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model NotificationBroadcast {
  id          String          @id @default(uuid())
  title       String
  message     String          @db.Text
  createdById String
  targetRole  BroadcastTarget
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  createdBy User @relation(fields: [createdById], references: [id])
}

enum BroadcastTarget {
  ALL
  SUPER_ADMIN
  PRESIDENT
  FOUNDER
  CHAIRMAN
  HR_OPERATIONS_MANAGER
  HR_ADMIN_MANAGER
  ADMIN_OFFICER
  HR_MANAGER
  ADMIN_MANAGER
  MEDICINE_MANAGER
  EMPLOYEE
}

// ─── AUDIT LOG ────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── RECRUITMENT ──────────────────────────────────────────

model JobApplication {
  id                  String            @id @default(uuid())
  fullName            String
  email               String
  phone               String
  cnic                String?
  position            String
  branchId            String?
  resumeUrl           String?
  status              ApplicationStatus @default(APPLIED)
  appliedAt           DateTime          @default(now())
  interviewDate       DateTime?
  notes               String?
  interviewNotes      String?
  selectedSalary      Decimal?          @db.Decimal(10, 2)
  selectedDeptId      String?
  selectedBranchId    String?
  selectedDesignation String?
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
}

// ─── PHASE 3 EXTENSIONS ───────────────────────────────────

model AcademicQualification {
  id              String   @id @default(uuid())
  employeeId      String
  qualType        QualType @default(ACADEMIC)
  degree          String
  boardUniversity String
  obtainedMarks   String?
  totalMarks      String?
  marksType       String?
  cgpa            Decimal? @db.Decimal(3, 2)
  divisionGrade   String?
  status          String   @default("COMPLETED")
  startYear       Int?
  endYear         Int?
  createdAt       DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum QualType {
  ACADEMIC
  JOB_RELEVANT
}

model PreviousEmployment {
  id                  String   @id @default(uuid())
  employeeId          String
  organizationName    String
  ownerAdminName      String?
  contactNumber       String?
  postalAddress       String?
  totalExperience     String?
  relevantExperience  String?
  jobResponsibilities String?  @db.Text
  createdAt           DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model BranchChangeRequest {
  id         String           @id @default(uuid())
  employeeId String
  district   String
  purpose    String           @db.Text
  startDate  DateTime
  endDate    DateTime
  duration   Int
  status     OutstationStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  notes      String?
  createdAt  DateTime         @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

enum OutstationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model AllegationAcknowledgement {
  id             String   @id @default(uuid())
  letterId       String   @unique
  employeeId     String
  acknowledgedAt DateTime @default(now())
  ipAddress      String?
  createdAt      DateTime @default(now())

  letter   Letter   @relation(fields: [letterId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model LocationValue {
  id        String   @id @default(uuid())
  type      String
  value     String
  province  String?
  city      String?
  createdAt DateTime @default(now())

  @@unique([type, value])
}

model AdvanceLoanRequest {
  id               String    @id @default(uuid())
  employeeId       String
  type             String
  amount           Decimal   @db.Decimal(10, 2)
  reason           String    @db.Text
  status           String    @default("PENDING")
  approvedBy       String?
  approvedAt       DateTime?
  rejectedBy       String?
  rejectionReason  String?
  repaymentMonths  Int?
  monthlyDeduction Decimal?  @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}
